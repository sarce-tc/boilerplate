@*
    Dumb arqueo dialog. Collects the declared (counted) balance and returns the form model to the
    smart page, which performs the close and shows the result. Shows the live expected balance as a
    reference — the server computes the authoritative difference.
*@
@using Microservice.Client.Application.Validation
@using Microservice.Client.Features.CashRegister.Models

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">
            Saldo esperado (calculado): <strong>@ExpectedBalance.ToString("N2")</strong>
        </MudText>
        <EditForm Model="Model" OnValidSubmit="Submit">
            <FluentValidationValidator TModel="CloseSessionFormModel" />
            <MudNumericField @bind-Value="Model.DeclaredBalance" Label="Saldo declarado (contado)"
                             Variant="Variant.Outlined" Min="0" Format="N2"
                             For="@(() => Model.DeclaredBalance)" Class="mb-3" />
            <MudTextField @bind-Value="Model.ClosedBy" Label="Cerrada por (opcional)" Variant="Variant.Outlined" />
            <div class="d-flex justify-end mt-4" style="gap:.5rem">
                <MudButton OnClick="Cancel">Cancelar</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled"
                           Disabled="Busy">
                    @if (Busy) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                    Cerrar caja
                </MudButton>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public decimal ExpectedBalance { get; set; }
    [Parameter] public bool Busy { get; set; }

    private readonly CloseSessionFormModel Model = new();

    private void Submit() => Dialog.Close(DialogResult.Ok(Model));
    private void Cancel() => Dialog.Cancel();
}
